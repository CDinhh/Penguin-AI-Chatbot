{
  "version": 2,
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/chat/(.*)",
      "destination": "/api/chat.py"
    },
    {
      "source": "/api/chat",
      "destination": "/api/chat.py"
    },
    {
      "source": "/api/tts/(.*)",
      "destination": "/api/tts.js"
    },
    {
      "source": "/api/tts",
      "destination": "/api/tts.js"
    }
  ]
}
